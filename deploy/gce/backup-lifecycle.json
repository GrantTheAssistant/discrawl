{
  "rule": [
    { "action": { "type": "Delete" }, "condition": { "age": 30, "matchesPrefix": ["daily/"] } },
    { "action": { "type": "Delete" }, "condition": { "age": 365, "matchesPrefix": ["monthly/"] } },
    { "action": { "type": "Delete" }, "condition": { "age": 1, "isLive": false } }
  ]
}
